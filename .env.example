# Provider API keys — set the ones for providers you want to audit.
# At least one must be set (or OLLAMA_BASE_URL for a free local run).

OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
MISTRAL_API_KEY=...
TOGETHER_API_KEY=...
FIREWORKS_API_KEY=...
GROQ_API_KEY=...

# Ollama (local, no API key needed). Default: http://ollama:11434 in docker compose.
# OLLAMA_BASE_URL=http://localhost:11434
